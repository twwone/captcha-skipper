{
  "manifest_version": 3,
  "name": "CAPTCHA 封鎖器",
  "version": "2.0.0",
  "description": "網路層封鎖 reCAPTCHA / hCaptcha 腳本載入，並注入假 API 避免網頁出錯",
  "permissions": [
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": ["*://*/*"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "captcha_block",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["shim.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
